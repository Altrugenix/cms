{
  "name": "@altrugenix/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "cms": "./bin/cms.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@altrugenix/database": "workspace:*",
    "@altrugenix/generators": "workspace:*",
    "@altrugenix/schema": "workspace:*",
    "@altrugenix/types": "workspace:*"
  }
}
