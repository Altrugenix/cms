{
  "name": "@arche-cms/cms",
  "version": "0.1.0",
  "type": "module",
  "bin": "bin/cms.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arche-cms/auth": "^0.1.0",
    "@arche-cms/core": "^0.1.0",
    "@arche-cms/database": "^0.1.0",
    "@arche-cms/generators": "^0.1.0",
    "@arche-cms/graphql": "^0.1.0",
    "@arche-cms/permissions": "^0.1.0",
    "@arche-cms/plugins": "^0.1.0",
    "@arche-cms/rest-api": "^0.1.0",
    "@arche-cms/schema": "^0.1.0",
    "@arche-cms/storage": "^0.1.0",
    "@arche-cms/types": "^0.1.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "fastify": "^5.3.2",
    "graphql": "^16.0.0",
    "mercurius": "^16.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arche-CMS/arche-cms.git",
    "directory": "packages/cms"
  }
}
